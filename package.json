{
  "name": "assetflow",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "git config --unset core.hooksPath || echo ok && npx lefthook install || echo ok",
    "webapp:dev": "turbo run dev --filter=@assetflow/webapp",
    "webapp:dev:staging": "pnpm --filter @assetflow/webapp run staging:dev",
    "webapp:dev:production": "pnpm --filter @assetflow/webapp run production:dev",
    "webapp:build": "turbo run build --filter=@assetflow/webapp",
    "webapp:test": "pnpm --filter @assetflow/webapp test",
    "webapp:lint": "pnpm --filter @assetflow/webapp lint",
    "webapp:doctor": "pnpm --filter @assetflow/webapp run doctor",
    "webapp:validate": "pnpm --filter @assetflow/webapp validate",
    "webapp:start": "pnpm --filter @assetflow/webapp start:local",
    "webapp:setup": "pnpm --filter @assetflow/webapp run setup",
    "webapp:deploy:staging": "fly deploy --remote-only --app assetflow-webapp-staging --dockerfile apps/webapp/Dockerfile",
    "webapp:deploy:production": "fly deploy --remote-only --app assetflow-webapp --dockerfile apps/webapp/Dockerfile",
    "webapp:seed:reporting-demo": "pnpm --filter @assetflow/webapp seed:reporting-demo",
    "webapp:seed:reporting-demo:staging": "pnpm --filter @assetflow/webapp seed:reporting-demo:staging",
    "webapp:clean:reporting-demo": "pnpm --filter @assetflow/webapp clean:reporting-demo",
    "webapp:clean:reporting-demo:staging": "pnpm --filter @assetflow/webapp clean:reporting-demo:staging",
    "companion:dev": "pnpm --filter @assetflow/companion dev",
    "companion:dev:clear": "pnpm --filter @assetflow/companion dev:clear",
    "companion:dev:tunnel": "pnpm --filter @assetflow/companion dev:tunnel",
    "companion:build:ios": "pnpm --filter @assetflow/companion build:ios",
    "companion:build:ios:device": "pnpm --filter @assetflow/companion build:ios:device",
    "companion:build:android": "pnpm --filter @assetflow/companion build:android",
    "companion:prebuild": "pnpm --filter @assetflow/companion prebuild",
    "companion:prebuild:clean": "pnpm --filter @assetflow/companion prebuild:clean",
    "companion:test:e2e": "pnpm --filter @assetflow/companion test:e2e",
    "companion:test:e2e:suite": "pnpm --filter @assetflow/companion test:e2e:suite --",
    "companion:doctor": "pnpm --filter @assetflow/companion run doctor",
    "docs:dev": "turbo run dev --filter=@assetflow/docs",
    "docs:build": "turbo run build --filter=@assetflow/docs",
    "docs:preview": "pnpm --filter @assetflow/docs preview",
    "db:generate": "pnpm --filter @assetflow/database run db:generate",
    "db:prepare-migration": "pnpm --filter @assetflow/database run db:prepare-migration",
    "db:deploy-migration": "pnpm --filter @assetflow/database run db:deploy-migration",
    "db:prepare-migration:staging": "pnpm --filter @assetflow/database run db:prepare-migration:staging",
    "db:deploy-migration:staging": "pnpm --filter @assetflow/database run db:deploy-migration:staging",
    "db:deploy-migration:production": "pnpm --filter @assetflow/database run db:deploy-migration:production",
    "db:reset": "pnpm --filter @assetflow/database run db:reset",
    "db:reset:staging": "pnpm --filter @assetflow/database run db:reset:staging"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@evilmartians/lefthook": "^2.1.5",
    "prettier": "3.0.3",
    "turbo": "^2.9.14"
  },
  "pnpm": {
    "overrides": {
      "@docsearch/react>react": "19.2.1",
      "@docsearch/react>react-dom": "19.2.1",
      "@tremor/react>react": "19.2.1",
      "@tremor/react>react-day-picker": "^9.14.0",
      "@tremor/react>react-dom": "19.2.1",
      "cross-spawn": "~7.0.6",
      "defu@<6.1.5": "6.1.5",
      "flatted@<3.4.0": "3.4.2",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.3",
      "p-map": "4.0.0",
      "path-to-regexp@<0.1.13": "0.1.13",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=3.0.0 <3.0.2": "3.0.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.10",
      "yaml@<1.10.3": "1.10.3",
      "yaml@>=2.0.0 <2.8.3": "2.8.3"
    },
    "patchedDependencies": {
      "expo-image@55.0.6": "patches/expo-image@55.0.6.patch"
    }
  },
  "engines": {
    "node": ">=22.20.0"
  },
  "packageManager": "pnpm@9.15.9"
}
